{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Work Hours",
  "description": "User's work hours in HH:MM-HH:MM format",
  "type": "string",
  "pattern": "^([0-1][0-9]|2[0-3]):[0-5][0-9]-([0-1][0-9]|2[0-3]):[0-5][0-9]$",
  "default": "09:00-17:00",
  "examples": ["09:00-17:00", "10:00-18:00", "08:30-16:30"]
}
