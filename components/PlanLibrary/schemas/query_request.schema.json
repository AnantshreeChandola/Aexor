{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plan Query Request",
  "description": "Schema for PlanLibrary query parameters",
  "type": "object",
  "oneOf": [
    {
      "title": "Intent Query",
      "required": ["intent_type"],
      "properties": {
        "intent_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "success_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.7
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 50
        },
        "recency_days": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Similarity Search",
      "required": ["query_text"],
      "properties": {
        "query_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "similarity_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.5
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10
        },
        "success_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.5
        }
      },
      "additionalProperties": false
    }
  ]
}
