{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlanLibrary Storage Schema",
  "description": "JSON Schema for plan storage requests and responses",
  
  "definitions": {
    "Plan": {
      "type": "object",
      "description": "Complete execution plan with signature",
      "properties": {
        "plan_id": {
          "type": "string",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "ULID identifier for the plan"
        },
        "intent": {
          "type": "object",
          "description": "User intent object",
          "properties": {
            "type": {"type": "string"},
            "description": {"type": "string"},
            "parameters": {"type": "object"}
          },
          "required": ["type"]
        },
        "graph": {
          "type": "array",
          "description": "Execution graph steps",
          "maxItems": 100,
          "items": {
            "type": "object",
            "properties": {
              "step_id": {"type": "string"},
              "operation": {"type": "string"},
              "inputs": {"type": "object"},
              "outputs": {"type": "object"}
            },
            "required": ["step_id", "operation"]
          }
        },
        "constraints": {
          "type": "object",
          "description": "Plan execution constraints"
        },
        "meta": {
          "type": "object",
          "description": "Plan metadata",
          "properties": {
            "created_at": {"type": "string", "format": "date-time"},
            "version": {"type": "string"}
          }
        }
      },
      "required": ["plan_id", "intent", "graph", "meta"]
    },
    
    "Signature": {
      "type": "object",
      "description": "Ed25519 signature object",
      "properties": {
        "signature": {
          "type": "string",
          "description": "Base64-encoded Ed25519 signature"
        },
        "public_key": {
          "type": "string",
          "description": "Base64-encoded Ed25519 public key"
        },
        "algorithm": {
          "type": "string",
          "enum": ["Ed25519"],
          "description": "Signature algorithm"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time",
          "description": "Signature creation timestamp"
        }
      },
      "required": ["signature", "public_key", "algorithm"]
    },
    
    "PlanOutcome": {
      "type": "object",
      "description": "Plan execution outcome",
      "properties": {
        "success": {
          "type": "boolean",
          "description": "Whether plan execution succeeded"
        },
        "error_type": {
          "type": "string",
          "description": "Error type if execution failed"
        },
        "error_details": {
          "type": "object",
          "description": "Detailed error information"
        },
        "execution_start": {
          "type": "string",
          "format": "date-time",
          "description": "Plan execution start time"
        },
        "execution_end": {
          "type": "string",
          "format": "date-time",
          "description": "Plan execution end time"
        },
        "total_steps": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of steps in plan"
        },
        "failed_step": {
          "type": "integer",
          "minimum": 0,
          "description": "Step index where execution failed (if applicable)"
        },
        "context_data": {
          "type": "object",
          "description": "Additional execution context"
        }
      },
      "required": ["success", "execution_start", "execution_end", "total_steps"]
    },
    
    "PlanMetrics": {
      "type": "object",
      "description": "Plan execution performance metrics",
      "properties": {
        "preview_latency_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Preview operation latency in milliseconds"
        },
        "execute_latency_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Execute operation latency in milliseconds"
        },
        "step_timings": {
          "type": "array",
          "description": "Individual step timing data",
          "items": {
            "type": "object",
            "properties": {
              "step_id": {"type": "string"},
              "duration_ms": {"type": "integer", "minimum": 0}
            },
            "required": ["step_id", "duration_ms"]
          }
        },
        "resource_usage": {
          "type": "object",
          "description": "Resource utilization metrics",
          "properties": {
            "memory_mb": {"type": "number", "minimum": 0},
            "cpu_percent": {"type": "number", "minimum": 0, "maximum": 100}
          }
        }
      },
      "required": ["execute_latency_ms"]
    }
  },
  
  "type": "object",
  "oneOf": [
    {
      "title": "StorePlanRequest",
      "description": "Request to store plan with outcome and metrics",
      "properties": {
        "plan": {"$ref": "#/definitions/Plan"},
        "signature": {"$ref": "#/definitions/Signature"},
        "outcome": {"$ref": "#/definitions/PlanOutcome"},
        "metrics": {"$ref": "#/definitions/PlanMetrics"}
      },
      "required": ["plan", "signature", "outcome", "metrics"]
    },
    {
      "title": "StorePlanResponse",
      "description": "Response from successful plan storage",
      "properties": {
        "status": {"type": "string", "enum": ["ok"]},
        "plan_id": {
          "type": "string",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "stored_at": {
          "type": "string",
          "format": "date-time"
        },
        "embedding_queued": {
          "type": "boolean",
          "description": "Whether embedding generation was queued"
        }
      },
      "required": ["status", "plan_id", "stored_at", "embedding_queued"]
    },
    {
      "title": "PlanQueryRequest", 
      "description": "Request to query plans by intent or similarity",
      "properties": {
        "intent_type": {
          "type": "string",
          "description": "Intent type to filter by"
        },
        "query_text": {
          "type": "string", 
          "description": "Text for similarity search"
        },
        "success_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Minimum success rate filter"
        },
        "similarity_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Minimum similarity score"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 50,
          "description": "Maximum number of results"
        },
        "recency_days": {
          "type": "integer",
          "minimum": 1,
          "description": "Filter plans from last N days"
        }
      }
    },
    {
      "title": "ErrorResponse",
      "description": "Error response format",
      "properties": {
        "status": {"type": "string", "enum": ["error"]},
        "error_code": {
          "type": "string",
          "enum": [
            "INVALID_PLAN_ID",
            "MALFORMED_PLAN", 
            "INVALID_SIGNATURE",
            "DUPLICATE_PLAN_ID",
            "PLAN_TOO_LARGE",
            "STORAGE_ERROR",
            "INVALID_QUERY",
            "VECTOR_SEARCH_UNAVAILABLE"
          ]
        },
        "message": {"type": "string"},
        "details": {"type": "object"}
      },
      "required": ["status", "error_code", "message"]
    }
  ]
}