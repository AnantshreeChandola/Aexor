{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Validation Result",
  "description": "Schema for pre-execution validation response.",
  "type": "object",
  "required": ["valid", "current_version"],
  "properties": {
    "valid": {
      "type": "boolean",
      "description": "Whether all referenced tools are still active."
    },
    "current_version": {
      "type": "integer",
      "minimum": 0,
      "description": "Current registry version."
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_id", "reason"],
        "properties": {
          "tool_id": {
            "type": "string",
            "description": "Tool ID that has an issue."
          },
          "reason": {
            "type": "string",
            "enum": ["TOOL_NOT_FOUND", "TOOL_DEACTIVATED"],
            "description": "Reason the tool is invalid."
          }
        },
        "additionalProperties": false
      },
      "default": [],
      "description": "List of issues found during validation."
    }
  },
  "additionalProperties": false
}
