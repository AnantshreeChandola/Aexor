{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditQueryResult",
  "description": "Schema for paginated audit query results",
  "type": "object",
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "$ref": "audit_event.schema.json"
      }
    },
    "next_cursor": {
      "type": ["string", "null"]
    },
    "total_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": ["events", "total_count"],
  "additionalProperties": false
}
