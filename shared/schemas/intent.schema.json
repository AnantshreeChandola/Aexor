{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://personal-agent.dev/schemas/intent.schema.json",
  "title": "Intent",
  "description": "User intent input contract (GLOBAL_SPEC v2 §2.2)",
  "type": "object",
  "required": ["intent", "entities", "constraints", "tz", "user_id"],
  "properties": {
    "intent": {
      "type": "string",
      "description": "Action type (e.g., 'schedule_meeting', 'book_flight', 'find_restaurant')",
      "minLength": 1,
      "examples": ["schedule_meeting", "book_flight", "send_email"]
    },
    "entities": {
      "type": "object",
      "description": "Extracted entities from user input",
      "additionalProperties": true,
      "maxProperties": 100,
      "examples": [
        {
          "contact_name": "Alice",
          "date_preference": "next week",
          "time_preference": "Tuesday at 10 AM"
        }
      ]
    },
    "constraints": {
      "type": "object",
      "description": "User-specified constraints or preferences",
      "additionalProperties": true,
      "maxProperties": 100,
      "examples": [
        {
          "max_price": 500,
          "duration_min": 30,
          "location": "downtown"
        }
      ]
    },
    "tz": {
      "type": "string",
      "description": "User timezone (IANA format)",
      "default": "America/Chicago",
      "pattern": "^[A-Za-z_]+/[A-Za-z_]+$",
      "examples": ["America/Chicago", "America/New_York", "Europe/London"]
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique user identifier"
    },
    "context_budget": {
      "type": ["integer", "null"],
      "description": "Context tier budget (1-5, see GLOBAL_SPEC §7). If null, system intelligently decides based on intent complexity and user preferences. Default: null (system decides)",
      "minimum": 1,
      "maximum": 5,
      "default": null
    },
    "session_id": {
      "type": "string",
      "description": "Optional session identifier for multi-turn conversations"
    },
    "trace_id": {
      "type": "string",
      "description": "Distributed tracing correlation ID (OpenTelemetry compatible, 32-char hex)",
      "pattern": "^[0-9a-f]{32}$",
      "examples": ["4bf92f3577b34da6a3ce929d0e0e4736"]
    }
  },
  "additionalProperties": false
}
