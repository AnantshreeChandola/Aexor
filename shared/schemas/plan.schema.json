{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://personal-agent.dev/schemas/plan.schema.json",
  "title": "Plan",
  "description": "Deterministic execution plan with adaptive execution points (GLOBAL_SPEC v3.0 §2.3)",
  "type": "object",
  "required": ["plan_id", "intent", "graph", "constraints", "plugins", "meta"],
  "properties": {
    "plan_id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID unique plan identifier"
    },
    "intent": {
      "$ref": "intent.schema.json",
      "description": "Original user intent"
    },
    "trace_id": {
      "type": "string",
      "description": "Distributed tracing correlation ID (inherited from intent or generated)",
      "pattern": "^[0-9a-f]{32}$",
      "examples": ["4bf92f3577b34da6a3ce929d0e0e4736"]
    },
    "plan_revision": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Plan revision number. Revision 0 is the initial immutable plan. Each spawn event increments this."
    },
    "graph": {
      "type": "array",
      "description": "Execution steps graph",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["step", "mode", "role", "uses", "call", "args"],
        "properties": {
          "step": {
            "type": "integer",
            "minimum": 1,
            "description": "Step number (1-indexed)"
          },
          "mode": {
            "type": "string",
            "enum": ["interactive", "durable"],
            "description": "Execution mode"
          },
          "role": {
            "type": "string",
            "enum": ["Fetcher", "Analyzer", "Watcher", "Resolver", "Booker", "Notifier", "Reasoner"],
            "description": "Runtime agent role"
          },
          "type": {
            "type": "string",
            "enum": ["api", "llm_reasoning", "policy_check"],
            "default": "api",
            "description": "Step type: api (MCP tool invocation), llm_reasoning (Anthropic API), policy_check (PolicyEngine evaluation)"
          },
          "trust_level": {
            "type": ["string", "null"],
            "enum": ["untrusted_input", "trusted", null],
            "default": null,
            "description": "LLM trust tier. untrusted_input = Tier 1 (sandboxed, no tools), trusted = Tier 2 (agent reasoning, MCP tools). null for non-LLM steps."
          },
          "uses": {
            "type": "string",
            "description": "Tool/connector ID (e.g., 'google.calendar', 'slack')",
            "minLength": 1
          },
          "call": {
            "type": "string",
            "description": "Operation to call (e.g., 'create_event', 'send_message')",
            "minLength": 1
          },
          "args": {
            "type": "object",
            "description": "Arguments for the operation",
            "additionalProperties": true,
            "maxProperties": 100
          },
          "after": {
            "type": "array",
            "description": "Dependency step numbers (optional, empty for parallel execution)",
            "items": {
              "type": "integer",
              "minimum": 1
            },
            "default": []
          },
          "context_from": {
            "type": "array",
            "description": "Step numbers whose outputs are passed as context to this step (for Reasoner steps)",
            "items": {
              "type": "integer",
              "minimum": 1
            },
            "default": []
          },
          "can_spawn": {
            "type": "boolean",
            "default": false,
            "description": "Whether this step can spawn new steps at runtime (Reasoner only, PolicyEngine-bounded)"
          },
          "max_spawned_steps": {
            "type": ["integer", "null"],
            "minimum": 1,
            "maximum": 10,
            "default": null,
            "description": "Maximum steps this step can spawn (cap: 10). null if can_spawn is false."
          },
          "spawned_by": {
            "type": ["integer", "null"],
            "default": null,
            "description": "Step number that spawned this step at runtime. null for original plan steps."
          },
          "policy_ref": {
            "type": ["string", "null"],
            "default": null,
            "description": "PolicyEngine rule reference. Required for Reasoner and policy_check steps."
          },
          "reasoning_config": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "description": "LLM reasoning configuration for llm_reasoning steps",
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "Anthropic model ID (e.g., 'claude-sonnet-4-5-20250929')"
                  },
                  "temperature": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "max_tokens": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 16384
                  },
                  "system_prompt_ref": {
                    "type": "string",
                    "description": "Reference to a registered system prompt template"
                  },
                  "output_schema_ref": {
                    "type": "string",
                    "description": "Reference to a JSON schema for structured output validation"
                  }
                },
                "additionalProperties": false
              }
            ],
            "default": null,
            "description": "Reasoning configuration. Required for llm_reasoning steps, null otherwise."
          },
          "timeout_s": {
            "type": "integer",
            "description": "Step timeout in seconds (fails if exceeded, supports fault isolation)",
            "minimum": 5,
            "maximum": 3600,
            "default": 30
          },
          "deadline": {
            "type": "string",
            "format": "date-time",
            "description": "Hard deadline for durable mode (ISO 8601, optional)"
          },
          "gate_id": {
            "type": "string",
            "description": "HITL gate identifier (optional, for user confirmation)",
            "pattern": "^gate-[A-Za-z0-9]+$"
          },
          "dry_run": {
            "type": "boolean",
            "description": "Preview mode flag",
            "default": true
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "skipped"],
            "default": "pending",
            "description": "Runtime execution status (not part of plan signature)"
          },
          "result": {
            "type": ["object", "null"],
            "default": null,
            "description": "Runtime step result (not part of plan signature)"
          },
          "error": {
            "type": ["object", "null"],
            "default": null,
            "description": "Runtime error details (not part of plan signature)"
          },
          "execute_mode": {
            "type": ["string", "null"],
            "enum": ["preview_only", "execute_only", "both", null],
            "default": null,
            "description": "Execution mode override for preview/execute phases"
          }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "object",
      "description": "Plan-level constraints",
      "properties": {
        "scopes": {
          "type": "array",
          "description": "Required OAuth scopes (validated against allowlist)",
          "items": {
            "type": "string",
            "pattern": "^[a-z_]+\\.(read|write|admin)$"
          },
          "maxItems": 10,
          "uniqueItems": true,
          "examples": [["calendar.write", "contacts.read"]]
        },
        "ttl_s": {
          "type": "integer",
          "description": "Plan time-to-live in seconds",
          "minimum": 60,
          "maximum": 86400,
          "default": 900
        },
        "max_retries": {
          "type": "integer",
          "description": "Maximum retry attempts per step",
          "minimum": 0,
          "maximum": 5,
          "default": 3
        },
        "policy_version": {
          "type": "integer",
          "minimum": 0,
          "description": "PolicyEngine rules version snapshot at plan creation time"
        }
      },
      "additionalProperties": true
    },
    "plugins": {
      "type": "array",
      "description": "List of plugin IDs used in this plan",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "examples": [["google.calendar", "slack", "notion"]]
    },
    "meta": {
      "type": "object",
      "description": "Plan metadata",
      "required": ["created_at", "author", "canonical_hash"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp"
        },
        "author": {
          "type": "string",
          "description": "Plan author (e.g., 'planner@system')",
          "default": "planner@system"
        },
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Plan schema semantic version (e.g., 'v2.0.0')",
          "default": "v2.0.0"
        },
        "canonical_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 hash of canonical plan (JCS RFC 8785 sorted keys, excludes meta.canonical_hash and meta.created_at)",
          "examples": ["sha256:abc123..."]
        },
        "hash_algo": {
          "type": "string",
          "enum": ["sha256"],
          "default": "sha256",
          "description": "Hash algorithm used for canonical_hash"
        },
        "plan_revision": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Current plan revision (mirrors top-level plan_revision for meta completeness)"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
