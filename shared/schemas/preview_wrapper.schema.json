{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://personal-agent.dev/schemas/preview_wrapper.schema.json",
  "title": "Preview Wrapper",
  "description": "Preview response wrapper (GLOBAL_SPEC v2 §2.5)",
  "type": "object",
  "required": ["normalized", "source", "can_execute"],
  "properties": {
    "normalized": {
      "type": "object",
      "description": "Component-specific normalized payload (defined in component schemas)",
      "additionalProperties": true,
      "examples": [
        {
          "meeting_slots": [
            {"start": "2025-12-17T10:00:00", "end": "2025-12-17T10:30:00"},
            {"start": "2025-12-17T14:00:00", "end": "2025-12-17T14:30:00"}
          ]
        }
      ]
    },
    "source": {
      "type": "string",
      "const": "preview",
      "description": "Always 'preview' for preview responses"
    },
    "can_execute": {
      "type": "boolean",
      "description": "Whether execution is possible after this preview",
      "examples": [true, false]
    },
    "evidence": {
      "type": "array",
      "description": "Optional supporting evidence from preview execution",
      "items": {
        "$ref": "evidence.schema.json"
      },
      "default": []
    },
    "preview_cache_key": {
      "type": "string",
      "description": "Optional cache key for reusing preview state in execution",
      "pattern": "^cache:[a-zA-Z0-9_-]+$"
    },
    "warnings": {
      "type": "array",
      "description": "Optional warnings or notices for the user",
      "items": {
        "type": "string"
      },
      "examples": [["Alice may have conflicts at this time", "Rate limit approaching"]]
    }
  },
  "additionalProperties": false
}
