{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://personal-agent.dev/schemas/evidence.schema.json",
  "title": "Evidence Item",
  "description": "Typed context evidence item (GLOBAL_SPEC v2 §2.2)",
  "type": "object",
  "required": ["type", "key", "value", "confidence", "source_ref"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["preference", "history", "contact", "plan", "exemplar"],
      "description": "Evidence type classification"
    },
    "key": {
      "type": "string",
      "description": "Evidence key identifier",
      "minLength": 1,
      "examples": ["meeting_duration_min", "alice_email", "tuesday_preference"]
    },
    "value": {
      "description": "Evidence value (any JSON type)",
      "examples": [30, "alice@company.com", true, {"nested": "object"}]
    },
    "confidence": {
      "type": "number",
      "description": "Confidence score (0.0 - 1.0)",
      "minimum": 0.0,
      "maximum": 1.0,
      "examples": [0.82, 0.95, 0.67]
    },
    "source_ref": {
      "type": "string",
      "description": "Reference to source (e.g., 'kv:prefs/duration', 'vector:hist_123')",
      "minLength": 1,
      "examples": ["kv:prefs/duration", "vector:hist_456", "db:contacts/alice"]
    },
    "ttl_days": {
      "type": "integer",
      "description": "Time-to-live in days (optional)",
      "minimum": 1,
      "maximum": 3650,
      "examples": [365, 30, 7]
    },
    "tier": {
      "type": "integer",
      "description": "Context tier level (1-5, see GLOBAL_SPEC §7)",
      "minimum": 1,
      "maximum": 5
    }
  },
  "additionalProperties": false
}
